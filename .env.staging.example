NODE_ENV=staging
PORT=4000
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
# Server-only secret. Required to set app_metadata (role, vendor_id) during signup/onboarding.
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>
# Verify asymmetric (ES256) Supabase tokens via JWKS. When set, SUPABASE_JWT_SECRET is ignored.
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Legacy HS256 fallback only — used when SUPABASE_JWKS_URL is unset.
SUPABASE_JWT_SECRET=
RELEASE_VERSION=
COMMIT_SHA=
PAYSTACK_WEBHOOK_INBOX_MODE=database
INTERNAL_OPERATIONS_TOKEN=
FCM_PROJECT_ID=<firebase-project-id>
FCM_CLIENT_EMAIL=<firebase-service-account-client-email>
FCM_PRIVATE_KEY="<firebase-service-account-private-key-with-\n-newlines>"
