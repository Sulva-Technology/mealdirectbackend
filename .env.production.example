NODE_ENV=production
APP_NAME=Meal Direct API
HOST=0.0.0.0
PORT=4000
API_PREFIX=v1
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=10
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
# Server-only secret. Required to set app_metadata (role, vendor_id) during signup/onboarding.
SUPABASE_SERVICE_ROLE_KEY=<production-service-role-key>
# Verify asymmetric (ES256) Supabase tokens via JWKS. When set, SUPABASE_JWT_SECRET is ignored.
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Legacy HS256 fallback only — used when SUPABASE_JWKS_URL is unset.
SUPABASE_JWT_SECRET=<production-jwt-secret>
CORS_ALLOWED_ORIGINS=https://user.mealdirect.com,https://vendor.mealdirect.com,https://rider.mealdirect.com,https://admin.mealdirect.com
LOG_LEVEL=info
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
REQUEST_ID_HEADER=x-request-id
TRACE_ID_HEADER=x-trace-id
RELEASE_VERSION=production
COMMIT_SHA=<deployed-sha>
RESERVATION_TTL_SECONDS=900
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=<production-paystack-secret>
PAYSTACK_WEBHOOK_INBOX_MODE=database
INTERNAL_OPERATIONS_TOKEN=<production-operations-token>
PRODUCTION_API_BASE_URL=https://api.mealdirect.com
SMOKE_FRONTEND_ORIGINS=https://user.mealdirect.com,https://vendor.mealdirect.com,https://rider.mealdirect.com,https://admin.mealdirect.com
