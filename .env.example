NODE_ENV=development
APP_NAME=Meal Direct API
HOST=0.0.0.0
PORT=4000
API_PREFIX=v1
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_ANON_KEY=
# Server-only secret. Required to set app_metadata (role, vendor_id) during signup/onboarding.
SUPABASE_SERVICE_ROLE_KEY=
# Verify asymmetric (ES256) Supabase tokens via JWKS. When set, SUPABASE_JWT_SECRET is ignored.
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# Legacy HS256 fallback only — used when SUPABASE_JWKS_URL is unset.
SUPABASE_JWT_SECRET=
CORS_ALLOWED_ORIGINS=https://user.mealdirectly.com,https://vendor.mealdirectly.com,https://rider.mealdirectly.com,https://admin.mealdirectly.com,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
# Base URLs used to build Supabase auth email redirect links (must be allow-listed in Supabase auth settings).
APP_URL_CUSTOMER=https://user.mealdirectly.com
APP_URL_VENDOR=https://vendor.mealdirectly.com
APP_URL_RIDER=https://rider.mealdirectly.com
LOG_LEVEL=info
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
REQUEST_ID_HEADER=x-request-id
TRACE_ID_HEADER=x-trace-id
RELEASE_VERSION=local
COMMIT_SHA=unknown
RESERVATION_TTL_SECONDS=900
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_INBOX_MODE=database
INTERNAL_OPERATIONS_TOKEN=
