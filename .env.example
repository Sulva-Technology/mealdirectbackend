NODE_ENV=development
APP_NAME=Meal Direct API
HOST=0.0.0.0
PORT=4000
API_PREFIX=v1
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_SSL=false
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_SECRET=
CORS_ALLOWED_ORIGINS=https://user.mealdirect.com,https://vendor.mealdirect.com,https://rider.mealdirect.com,https://admin.mealdirect.com,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
LOG_LEVEL=info
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
REQUEST_ID_HEADER=x-request-id
TRACE_ID_HEADER=x-trace-id
RELEASE_VERSION=local
COMMIT_SHA=unknown
RESERVATION_TTL_SECONDS=900
PAYSTACK_SECRET_KEY=
INTERNAL_OPERATIONS_TOKEN=
