NODE_ENV=test
HOST=127.0.0.1
PORT=0
API_PREFIX=v1
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
E2E_DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=2
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_SECRET=<hosted-e2e-jwt-secret>
CORS_ALLOWED_ORIGINS=https://user.mealdirectly.com,https://vendor.mealdirectly.com,https://rider.mealdirectly.com,https://admin.mealdirectly.com
LOG_LEVEL=silent
BODY_LIMIT_BYTES=1048576
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
REQUEST_ID_HEADER=x-request-id
TRACE_ID_HEADER=x-trace-id
RELEASE_VERSION=e2e
COMMIT_SHA=e2e
RESERVATION_TTL_SECONDS=900
PAYSTACK_BASE_URL=http://127.0.0.1:59999
PAYSTACK_SECRET_KEY=e2e-paystack-secret
PAYSTACK_WEBHOOK_INBOX_MODE=database
INTERNAL_OPERATIONS_TOKEN=e2e-operations-token
E2E_TEST_NAMESPACE=e2e_meal_direct_<unique_suffix>
