{
  "openapi": "3.0.0",
  "paths": {
    "/v1/health/live": {
      "get": {
        "operationId": "HealthController_live",
        "parameters": [],
        "responses": { "200": { "description": "The API process is running." } },
        "tags": ["health"]
      }
    },
    "/v1/health/ready": {
      "get": {
        "operationId": "HealthController_ready",
        "parameters": [],
        "responses": {
          "200": { "description": "The API is ready to serve traffic." },
          "503": { "description": "A required dependency is unavailable." }
        },
        "tags": ["health"]
      }
    },
    "/v1/operations/status": {
      "get": {
        "operationId": "OperationsController_status",
        "parameters": [],
        "responses": {
          "200": { "description": "Internal operational status for authorized administrators." },
          "401": { "description": "Operations token missing or invalid." }
        },
        "security": [{ "operationsToken": [] }],
        "tags": ["operations"]
      }
    },
    "/v1/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": { "description": "The authenticated Meal Direct actor context." },
          "401": { "description": "Missing, invalid, or expired Supabase JWT." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["auth"]
      }
    },
    "/v1/orders": {
      "post": {
        "operationId": "OrdersController_createOrder",
        "parameters": [],
        "responses": {
          "201": { "description": "Order was created idempotently and inventory was reserved." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["orders"]
      }
    },
    "/v1/payments/webhooks/paystack": {
      "post": {
        "operationId": "PaystackWebhookController_handlePaystackWebhook",
        "parameters": [],
        "responses": {
          "202": { "description": "Paystack webhook was verified and accepted idempotently." },
          "401": { "description": "Missing or invalid Paystack signature." }
        },
        "tags": ["payments"]
      }
    },
    "/v1/settlements/vendors/{vendorId}/daily": {
      "post": {
        "operationId": "SettlementsController_generateVendorDailySettlement",
        "parameters": [],
        "responses": {
          "201": { "description": "Vendor daily settlement was generated idempotently." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["settlements"]
      }
    },
    "/v1/settlements/riders/{riderId}/daily": {
      "post": {
        "operationId": "SettlementsController_generateRiderDailySettlement",
        "parameters": [],
        "responses": {
          "201": { "description": "Rider daily settlement was generated idempotently." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["settlements"]
      }
    }
  },
  "info": {
    "title": "Meal Direct API",
    "description": "Stable REST API for Meal Direct web and future mobile clients.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "supabaseAuth": {
        "scheme": "bearer",
        "bearerFormat": "Supabase JWT",
        "type": "http",
        "description": "Supabase Auth access token."
      },
      "idempotencyKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Idempotency-Key",
        "description": "Required for important mutations such as order creation and payments."
      },
      "requestId": {
        "type": "apiKey",
        "in": "header",
        "name": "x-request-id",
        "description": "Optional caller-provided request ID. The API echoes or generates one."
      },
      "operationsToken": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Internal operations token. Temporary until Super Admin JWT/RBAC is implemented."
      }
    },
    "schemas": {
      "CursorPaginationMetaDto": {
        "type": "object",
        "properties": {
          "hasMore": { "type": "boolean", "description": "True when another page is available." },
          "limit": {
            "type": "number",
            "description": "Limit applied to the current page.",
            "minimum": 1
          },
          "nextCursor": { "type": "string", "description": "Cursor to request the next page." }
        },
        "required": ["hasMore", "limit"]
      },
      "CursorPaginationQueryDto": {
        "type": "object",
        "properties": {
          "cursor": {
            "type": "string",
            "description": "Opaque cursor returned by the previous page.",
            "example": "eyJpZCI6Im9yZGVyLTEifQ"
          },
          "limit": {
            "type": "number",
            "description": "Maximum number of records to return.",
            "default": 20,
            "maximum": 100,
            "minimum": 1
          }
        }
      },
      "DateRangeQueryDto": {
        "type": "object",
        "properties": {
          "dateFrom": {
            "type": "string",
            "description": "Inclusive ISO-8601 lower bound for date filtering.",
            "example": "2026-06-15T00:00:00.000Z"
          },
          "dateTo": {
            "type": "string",
            "description": "Inclusive ISO-8601 upper bound for date filtering.",
            "example": "2026-06-16T00:00:00.000Z"
          }
        }
      },
      "ErrorBodyDto": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "example": "VALIDATION_FAILED" },
          "message": { "type": "string", "example": "Request validation failed" },
          "requestId": {
            "type": "string",
            "description": "Request identifier for support and log correlation."
          },
          "details": {
            "description": "Safe machine-readable error details.",
            "type": "array",
            "items": { "type": "object" }
          }
        },
        "required": ["code", "message"]
      },
      "ErrorEnvelopeDto": {
        "type": "object",
        "properties": { "error": { "$ref": "#/components/schemas/ErrorBodyDto" } },
        "required": ["error"]
      },
      "ListEnvelopeDto": {
        "type": "object",
        "properties": {
          "data": {
            "description": "Response list payload.",
            "type": "array",
            "items": { "type": "object" }
          },
          "pagination": { "$ref": "#/components/schemas/CursorPaginationMetaDto" },
          "meta": { "type": "object", "description": "Optional response metadata." }
        },
        "required": ["data", "pagination"]
      },
      "MoneyDto": {
        "type": "object",
        "properties": {
          "amountCents": {
            "type": "number",
            "description": "Amount in the smallest currency unit.",
            "example": 250000,
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "description": "ISO-4217 uppercase currency code.",
            "example": "NGN",
            "pattern": "^[A-Z]{3}$"
          }
        },
        "required": ["amountCents", "currency"]
      },
      "SortQueryDto": {
        "type": "object",
        "properties": {
          "sort": {
            "type": "string",
            "description": "Sort expression in field:direction form, or -field for descending.",
            "example": "createdAt:desc"
          }
        }
      },
      "StatusQueryDto": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "description": "Module-specific status filter." }
        }
      },
      "SuccessEnvelopeDto": {
        "type": "object",
        "properties": {
          "data": { "type": "object", "description": "Response payload." },
          "meta": { "type": "object", "description": "Optional response metadata." }
        },
        "required": ["data"]
      },
      "UuidParamDto": {
        "type": "object",
        "properties": { "id": { "type": "string", "format": "uuid" } },
        "required": ["id"]
      }
    }
  }
}
