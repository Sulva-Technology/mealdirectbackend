  "info": {
    "title": "Meal Direct API",
    "description": "Stable REST API for Meal Direct web and future mobile clients.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "supabaseAuth": {
        "scheme": "bearer",
        "bearerFormat": "Supabase JWT",
        "type": "http",
        "description": "Supabase Auth access token."
      },
      "idempotencyKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Idempotency-Key",
        "description": "Required for important mutations such as order creation and payments."
      },
      "requestId": {
        "type": "apiKey",
        "in": "header",
        "name": "x-request-id",
        "description": "Optional caller-provided request ID. The API echoes or generates one."
      },
      "operationsToken": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Internal operations token. Temporary until Super Admin JWT/RBAC is implemented."
      }
    },
    "schemas": {
      "MeActorDto": {
        "type": "object",
        "properties": {
          "userId": { "type": "string", "format": "uuid" },
          "role": {
            "type": "string",
            "enum": ["customer", "vendor", "rider", "campus_admin", "super_admin"]
          },
          "email": { "type": "string" },
          "campusId": { "type": "string", "format": "uuid" },
          "vendorId": { "type": "string", "format": "uuid" },
          "riderId": { "type": "string", "format": "uuid" }
        },
        "required": ["userId", "role"]
      },
      "ProfileRecordDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "nullable": true },
          "displayName": { "type": "string", "nullable": true },
          "phoneNumber": { "type": "string", "nullable": true },
          "avatarUrl": { "type": "string", "nullable": true },
          "accountStatus": { "type": "string", "enum": ["active", "suspended", "deactivated"] },
          "defaultCampusId": { "type": "string", "format": "uuid", "nullable": true },
          "defaultLocationId": { "type": "string", "format": "uuid", "nullable": true },
          "onboardingCompletedAt": { "type": "string", "nullable": true },
          "onboardingCompleted": { "type": "boolean" },
          "lastSeenAt": { "type": "string", "nullable": true },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        },
        "required": ["id", "accountStatus", "onboardingCompleted", "createdAt", "updatedAt"]
      },
      "CampusMembershipDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "campusId": { "type": "string", "format": "uuid" },
          "campusName": { "type": "string" },
          "campusSlug": { "type": "string" },
          "timezone": { "type": "string" },
          "currency": { "type": "string" },
          "countryCode": { "type": "string" },
          "active": { "type": "boolean" },
          "joinedAt": { "type": "string" }
        },
        "required": [
          "id",
          "campusId",
          "campusName",
          "campusSlug",
          "timezone",
          "currency",
          "countryCode",
          "active",
          "joinedAt"
        ]
      },
      "VendorMembershipDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "vendorId": { "type": "string", "format": "uuid" },
          "campusId": { "type": "string", "format": "uuid" },
          "vendorDisplayName": { "type": "string" },
          "vendorSlug": { "type": "string" },
          "role": { "type": "string", "enum": ["owner", "staff"] },
          "active": { "type": "boolean" }
        },
        "required": [
          "id",
          "vendorId",
          "campusId",
          "vendorDisplayName",
          "vendorSlug",
          "role",
          "active"
        ]
      },
      "RiderProfileDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "campusId": { "type": "string", "format": "uuid" },
          "displayName": { "type": "string" },
          "phone": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "verified", "suspended", "deactivated"]
          },
          "active": { "type": "boolean" }
        },
        "required": ["id", "campusId", "displayName", "phone", "status", "active"]
      },
      "AdminMembershipDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "campusId": { "type": "string", "format": "uuid", "nullable": true },
          "campusName": { "type": "string", "nullable": true },
          "role": { "type": "string", "enum": ["campus_admin", "super_admin"] },
          "active": { "type": "boolean" },
          "grantedAt": { "type": "string" }
        },
        "required": ["id", "role", "active", "grantedAt"]
      },
      "MeSessionDto": {
        "type": "object",
        "properties": {
          "actor": { "$ref": "#/components/schemas/MeActorDto" },
          "profile": { "$ref": "#/components/schemas/ProfileRecordDto" },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["customer", "vendor", "rider", "campus_admin", "super_admin"]
            }
          },
          "campuses": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CampusMembershipDto" }
          },
          "vendorMemberships": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/VendorMembershipDto" }
          },
          "riderProfiles": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RiderProfileDto" }
