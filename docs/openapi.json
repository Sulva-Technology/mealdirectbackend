{
  "openapi": "3.0.0",
  "paths": {
    "/v1/health/live": {
      "get": {
        "operationId": "HealthController_live",
        "parameters": [],
        "responses": { "200": { "description": "The API process is running." } },
        "tags": ["health"]
      }
    },
    "/v1/health/ready": {
      "get": {
        "operationId": "HealthController_ready",
        "parameters": [],
        "responses": {
          "200": { "description": "The API is ready to serve traffic." },
          "503": { "description": "A required dependency is unavailable." }
        },
        "tags": ["health"]
      }
    },
    "/v1/operations/status": {
      "get": {
        "operationId": "OperationsController_status",
        "parameters": [],
        "responses": {
          "200": { "description": "Internal operational status for authorized administrators." },
          "401": { "description": "Operations token missing or invalid." }
        },
        "security": [{ "operationsToken": [] }],
        "tags": ["operations"]
      }
    },
    "/v1/auth/me": {
      "get": {
        "operationId": "AuthController_me",
        "parameters": [],
        "responses": {
          "200": { "description": "The authenticated Meal Direct actor context." },
          "401": { "description": "Missing, invalid, or expired Supabase JWT." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["auth"]
      }
    },
    "/v1/orders": {
      "post": {
        "operationId": "OrdersController_createOrder",
        "parameters": [],
        "responses": {
          "201": { "description": "Order was created idempotently and inventory was reserved." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["orders"]
      }
    },
    "/v1/payments/webhooks/paystack": {
      "post": {
        "operationId": "PaystackWebhookController_handlePaystackWebhook",
        "parameters": [],
        "responses": {
          "202": { "description": "Paystack webhook was verified and accepted idempotently." },
          "401": { "description": "Missing or invalid Paystack signature." }
        },
        "tags": ["payments"]
      }
    },
    "/v1/settlements/vendors/{vendorId}/daily": {
      "post": {
        "operationId": "SettlementsController_generateVendorDailySettlement",
        "parameters": [],
        "responses": {
          "201": { "description": "Vendor daily settlement was generated idempotently." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["settlements"]
      }
    },
    "/v1/settlements/riders/{riderId}/daily": {
      "post": {
        "operationId": "SettlementsController_generateRiderDailySettlement",
        "parameters": [],
        "responses": {
          "201": { "description": "Rider daily settlement was generated idempotently." }
        },
        "security": [{ "supabaseAuth": [] }],
        "tags": ["settlements"]
      }
    }
  },
  "info": {
    "title": "Meal Direct API",
    "description": "Stable REST API for Meal Direct web and future mobile clients.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "supabaseAuth": {
        "scheme": "bearer",
        "bearerFormat": "Supabase JWT",
        "type": "http",
        "description": "Supabase Auth access token."
      },
      "idempotencyKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Idempotency-Key",
        "description": "Required for important mutations such as order creation and payments."
      },
      "requestId": {
        "type": "apiKey",
        "in": "header",
        "name": "x-request-id",
        "description": "Optional caller-provided request ID. The API echoes or generates one."
      },
      "operationsToken": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Internal operations token. Temporary until Super Admin JWT/RBAC is implemented."
      }
    },
    "schemas": {}
  }
}
