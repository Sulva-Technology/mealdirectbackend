{
  "name": "meal-direct-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Meal Direct modular monolith API and Supabase database migrations.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "worker": "tsx src/worker.ts",
    "worker:prod": "node dist/worker.js",
    "cron": "tsx src/cron.ts",
    "cron:prod": "node dist/cron.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "test:production": "vitest run --config vitest.production.config.ts",
    "test:db-integration": "pnpm test:production",
    "test:e2e": "vitest run test/e2e",
    "test:no-skips": "node scripts/check-critical-tests.mjs",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "pnpm openapi:generate && git diff --exit-code -- docs/openapi.json docs/openapi.yaml",
    "smoke:api": "node scripts/smoke-api.mjs",
    "supabase:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:lint": "node scripts/lint-migrations.mjs && supabase db lint",
    "db:test": "supabase test db",
    "db:types": "supabase gen types typescript --local --schema public > supabase/types/database.types.ts",
    "db:status": "supabase migration list --local",
    "db:diff:check": "node scripts/check-schema-diff.mjs",
    "db:ci": "pnpm db:reset && pnpm db:test && pnpm db:lint && pnpm db:types && pnpm db:diff:check",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm test:no-skips && pnpm openapi:check && pnpm db:ci"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-fastify": "^11.1.26",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.26",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
